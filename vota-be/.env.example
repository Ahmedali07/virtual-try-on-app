# Server
HOST=0.0.0.0
PORT=8000
# Public base URL used in JSON responses (no trailing slash). Leave empty to derive from each request.
# For Next.js dev proxy, set to your frontend origin + /vtoa-api so image URLs are same-origin, e.g.:
# PUBLIC_BASE_URL=http://localhost:3000/vtoa-api
# Production (Render):
# PUBLIC_BASE_URL=https://vtoa-api.onrender.com
PUBLIC_BASE_URL=

# CORS — comma-separated origins (Next.js dev server by default)
# Production — include your Vercel app:
# CORS_ORIGINS=https://virtual-try-on-app-nu.vercel.app,http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Virtual try-on provider: huggingface | replicate | local ---
TRYON_PROVIDER=huggingface

# --- Hugging Face–compatible HTTP gateway (multipart two images) ---
# Replace the placeholder URL with your own inference HTTP endpoint that accepts:
#   - form field HF_HUMAN_FIELD (default: human_image) → user portrait JPEG
#   - form field HF_GARMENT_FIELD (default: garment_image) → garment JPEG
# and returns a raw image body or JSON containing an image URL.
HF_API_URL=https://api-inference.huggingface.co/models/your-org/your-vton-model
HF_API_TOKEN=
HF_HUMAN_FIELD=human_image
HF_GARMENT_FIELD=garment_image

# --- Replicate (OOTDiffusion — real diffusion try-on) ---
# Set TRYON_PROVIDER=replicate and provide REPLICATE_API_TOKEN (https://replicate.com/account/api-tokens).
# Default version pins viktorfa/oot_diffusion; override with another digest from the Replicate model page if needed.
REPLICATE_API_TOKEN=
REPLICATE_MODEL_VERSION=27c1edcff8d2ab01893c78e59118b9392da5542c93aef99e8c583910f1d55e1f
REPLICATE_STEPS=20
REPLICATE_GUIDANCE_SCALE=2.0
REPLICATE_POLL_INTERVAL_S=2.0
REPLICATE_MAX_WAIT_S=600

# Local checkpoint path (reserved for self-hosted weights)
LOCAL_MODEL_PATH=

# Max upload size in bytes (default 8 MiB)
MAX_UPLOAD_BYTES=8388608
